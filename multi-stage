# Stage 1: Build
FROM node:18 AS builder

# Set working directory
WORKDIR /app

# Copy package.json and install dependencies
COPY package*.json ./
RUN npm install

# Copy all application files
COPY . .

# Stage 2: Runtime
FROM node:18-slim

WORKDIR /app

# Copy only necessary files from builder
COPY --from=builder /app .

# Expose application port
EXPOSE 8090

# Start the app
CMD ["node", "app.js"]
